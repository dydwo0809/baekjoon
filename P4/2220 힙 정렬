#include <bits/stdc++.h>

using namespace std;


void swap(vector<int>& nums, int a, int b) {
    int temp = nums[a];
    nums[a] = nums[b];
    nums[b] = temp;
}


int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int n;
    cin >> n;

    vector<int> nums(n);
    for (int i = 0; i < n; i++) nums[i] = i + 1;

    for (int i = 0; i < n - 1; i++) {
        int p = i;
        while (p > 0) {
            int next_p = (p - 1) / 2;
            swap(nums, p, next_p);
            p = next_p;
        }
        swap(nums, 0, i + 1);
    }

    for (int i = 0; i < n; i++) cout << nums[i] << " ";
    cout << '\n';

    return 0;
}
