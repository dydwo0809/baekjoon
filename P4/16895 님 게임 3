import sys
input = sys.stdin.readline

n = int(input())
nums = list(map(int, input().split()))

answer = 0
for i in nums:
    answer ^= i

if answer == 0:
    print(0)
else:
    xor = []
    for i in range(n):
        temp = 0
        for j in range(n):
            if i != j:
                temp ^= nums[j]
        xor.append(temp)

    answer = 0
    for i in range(n):
        temp = nums[i]
        if temp >= xor[i]:
            answer += 1
    print(answer)
