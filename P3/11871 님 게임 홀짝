import sys
input = sys.stdin.readline


def sg(n):
    if n == 0:
        return 0
    elif n % 2 == 0:
        return n // 2 - 1
    else:
        return (n + 1) // 2


n = int(input())
nums = list(map(int, input().split()))

answer = 0
for num in nums:
    answer ^= sg(num)

if answer == 0:
    print("cubelover")
else:
    print("koosaga")
