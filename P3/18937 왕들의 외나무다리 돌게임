import sys
input = sys.stdin.readline


n = int(input())
nums = list(map(int, input().split()))

sg = 0
for num in nums:
    sg ^= (num - 2)

s = input().strip()
king = ["Blackking", "Whiteking"]
if s == "Blackking":
    index = 1
else:
    index = 0

if sg == 0:
    print(king[index])
else:
    print(king[1 - index])
