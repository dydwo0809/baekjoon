    for t in range(n):
        temp = points[t]
        u = [temp[0], temp[2]]
        d = [temp[0], temp[1]]
        if d[0] == p1[0] or d[0] == p2[0]:
            continue
        if u[0] == p1[0] or u[0] == p2[0]:
            continue
        if ccwP(p1, p2, u) == 0:
            count += 1
            if count > 1:
                return False
        if ccwP(p1, p2, u) < 0 or ccwP(p1, p2, d) > 0:
            return False
    return True


def maxSlope(up, down):
    l1 = len(down)
    l2 = len(up)
    j = 1
    temp_i = 0
    temp_j = 0
    for i in range(l1 - 1):
        while down[i][0] >= up[j][0]:
            j += 1
        while j < l2 - 1 and slope(down[i], down[i + 1]) <= slope(down[i], up[j + 1]):
            if slope(down[i], up[j]) > slope(down[i], up[j + 1]):
                j += 1
            else:
                break
        M = slope(down[i], up[j])
        if i == 0 and j == l2 - 1:
            if M >= slope(down[i], down[i + 1]) and slope(up[j - 1], up[j]) <= M:
                temp_i = i
                temp_j = j
                break

        if j == l2 - 1:
            if slope(down[i - 1], down[i]) >= M >= slope(down[i], down[i + 1]) and slope(up[j - 1], up[j]) <= M:
                temp_i = i
                temp_j = j
                break

        if i == 0:
            if M >= slope(down[i], down[i + 1]) and slope(up[j - 1], up[j]) <= M <= slope(up[j], up[j + 1]):
                temp_i = i
                temp_j = j
                break

        if slope(down[i - 1], down[i]) >= M >= slope(down[i], down[i + 1]) and slope(up[j - 1], up[j]) <= M <= slope(up[j], up[j + 1]):
            temp_i = i
            temp_j = j
            break

    i = temp_i
    j = temp_j
    M = slope(down[i], up[j])
    if check(down[i], up[j]):
        return M
    else:
        return "Impossible"


