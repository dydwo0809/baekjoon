#include <bits/stdc++.h>
using namespace std;


double dist(pair<double, double> p1, pair<double, double> p2){
	double result = 0;
	result += pow(p1.first - p2.first, 2);
	result += pow(p1.second - p2.second, 2);
	result = pow(result, 0.5);
	
	return result;
}


double dist2(pair<double, double> p1, pair<double, double> p2){
	double result = 0;
	result += pow(p1.first - p2.first, 2);
	result += pow(p1.second - p2.second, 2);
	
	return result;
}


int calc(pair<double, double> p1, pair<double, double> p2, vector<pair<double, double>> points){
	double a, b, d, norm, x, y, x1, y1, x2, y2;
	
	a = p2.first - p1.first;
	b = p2.second - p1.second;
	
	d = dist(p1, p2);
	norm = 1 - pow(d / 2, 2);
	norm = pow(norm, 0.5);

	a /= d;
	b /= d;

	a *= norm;
	b *= norm;

	x = (p1.first + p2.first) / 2;
	y = (p1.second + p2.second) / 2;

	x1 = x - b;
	y1 = y + a;

	x2 = x + b;
	y2 = y = a;

	int result = 1;

	int temp = 0;
	for (int i = 0; i < points.size(); i++){
		d = dist2(points[i], {x1, y1});
		if (d <= 1.0002) temp++;
	}
	if (temp > result) result = temp;

	temp = 0;
	for (int i = 0; i < points.size(); i++){
		d = dist2(points[i], {x2, y2});
		if (d <= 1.0002) temp++;
	}
	if (temp > result) result = temp;

	return result;
}


int main() {
	ios_base::sync_with_stdio(false);
	cin.tie(0);
	cout.tie(0);
	
	int m;
	while (true){
		cin >> m;
		if (m == 0) break;

		vector<pair<double, double>> points = {};
		double x, y;
		for (int i = 0; i < m; i++){
			cin >> x >> y;
			points.push_back({x, y});
		}

		int answer = 1;
		pair<double, double> p1, p2;
		for (int i = 0; i < m - 1; i++){
			for (int j = i + 1; j < m; j++){
				p1 = points[i];
				p2 = points[j];
				double d = dist(p1, p2);
				if (d > 2){
					continue;
				}
				int temp = calc(p1, p2, points);
				if (temp > answer) answer = temp;
			}
		}
		cout << answer << "\n";
	}

	return 0;
}
