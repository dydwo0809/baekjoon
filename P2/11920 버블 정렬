#include <bits/stdc++.h>

using namespace std;


int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, k;
    cin >> n >> k;
    vector<int> nums(n);
    vector<int> answer;

    for (int i = 0; i < n; i++) {
        cin >> nums[i];
    }

    priority_queue<int, vector<int>, greater<>> pq;
    for (int i = 0; i < k; i++){
        pq.push(nums[i]);
    }
    for (int i = k; i < n; i++){
        pq.push(nums[i]);
        int temp = pq.top(); pq.pop();
        answer.push_back(temp);
    }
    while (!pq.empty()){
        int temp = pq.top(); pq.pop();
        answer.push_back(temp);
    }
    for (int i = 0; i < n; i++){
        cout << answer[i] << " ";
    }
}
