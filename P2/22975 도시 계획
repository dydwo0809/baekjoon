import sys
input = sys.stdin.readline


n = int(input())
nums = list(map(int, input().split()))

line = []
for x1 in range(n - 1):
    for x2 in range(x1 + 1, n):
        y1 = nums[x1]
        y2 = nums[x2]
        slope = (y2 - y1) / (x2 - x1)
        line.append([slope, x1, x2])

line.sort(key=lambda x: (x[0], x[1]))
dp = [1] * n
for slope, x1, x2 in line:
    dp[x2] = max(dp[x2], dp[x1] + 1)

print(n - max(dp))
