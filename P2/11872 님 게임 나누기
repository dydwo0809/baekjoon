import sys
input = sys.stdin.readline

n = int(input())
nums = list(map(int, input().split()))
xor = 0
for num in nums:
    if num % 4 == 0:
        xor ^= num - 1
    elif num % 4 == 3:
        xor ^= num + 1
    else:
        xor ^= num

if xor > 0:
    print("koosaga")
else:
    print("cubelover")
