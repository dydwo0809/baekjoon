#include <bits/stdc++.h>
using namespace std;

typedef long long ll;


struct line {  
   mutable ll m, k, p;  
   bool operator<(const line &o) const { return m < o.m; }  
   bool operator<(ll x) const { return p < x; }  
};

struct LineContainer : multiset<line, less<>> {  
   //(for doubles, use inf = 1/.0, div(a,b) = a/b)  
   const static ll inf = LLONG_MAX;  

   ll div(ll a, ll b) { 
      return a / b - ((a ^ b) < 0 && a % b); 
   } 

   bool isect(iterator x, iterator y) {  
      if (y == end()) return x->p = inf, 0;  
      if (x->m == y->m) x->p = x->k > y->k ? inf : -inf;  
      else x->p = div(y->k - x->k, x->m - y->m);  
      return x->p >= y->p;  
   }  

   void add(ll m, ll k) { //add y = mx + k  
      auto z = insert({m, k}), y = z++, x = y;  
      while (isect(y, z)) z = erase(z);  
      if (x != begin() && isect(--x, y)) isect(x, y = erase(y));  
      while ((y = x) != begin() && (--x)->p >= y->p) isect(x, erase(y));  
   }  

   ll query(ll x) {  
      auto l = *lower_bound(x);  
      return l.m * x + l.k;  
   }  
} cht;

int main() {
   ios_base::sync_with_stdio(false);
   cin.tie(0);
   cout.tie(0);

   int n;
   cin >> n;

   vector<ll> nums(n + 1);
   for (int i = 1; i < n + 1; i++){
      cin >> nums[i];
   }

   vector<ll> s(n + 1);
   ll temp = 0;
   for (int i = 1; i < n + 1; i++){
      temp += nums[i];
      s[i] = temp;
   }

   vector<ll> ss(n + 1);
   temp = 0;
   for (ll i = 1; i < n + 1; i++){
      temp += nums[i] * i;
      ss[i] = temp;
   }

   ll answer = ss[n];

   for (ll i = 1; i < n + 1; i++){
      cht.add(i, -s[i - 1]);
      temp = cht.query(nums[i]) + ss[n] - nums[i] * i + s[i - 1];
      if (answer < temp){
         answer = temp;
      }
   }

   cht.clear();

   for (ll i = 1; i < n + 1; i++){
      cht.add(nums[i], s[i] - nums[i] * i);
      temp = cht.query(i) + ss[n] - s[i];
      if (answer < temp){
         answer = temp;
      }
   }

   cout << answer;

   return 0;
}
