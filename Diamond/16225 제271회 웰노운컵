import sys
input = sys.stdin.readline
import heapq


n = int(input())
A = list(map(int, input().split()))
B = list(map(int, input().split()))

AB = []
for i in range(n):
    AB.append((-A[i], B[i]))
AB.sort(key=lambda x: x[1])

answer = -AB[0][0]
heap = []
for i in range(1, n - 1):
    heapq.heappush(heap, AB[i])
    if i % 2 == 0:
        answer += -heapq.heappop(heap)[0]
print(answer)
