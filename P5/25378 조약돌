import sys
input = sys.stdin.readline


n = int(input())
nums = list(map(int, input().split()))

p = [[nums[i]] for i in range(n)]
cnt = 0
for i in range(1, n):
    for prev in p[i - 1]:
        curr = nums[i]
        if prev == curr:
            cnt += 1
            p[i] = []
            break
        if prev < curr:
            p[i].append(curr - prev)

print(n - cnt)
