import sys

input = sys.stdin.readline


def power(r, n, mod):
    result = 1
    while n > 0:
        if n % 2:
            result *= r
        r *= r
        n //= 2
        r %= mod
    return result


p = 1000000007
fac = [1]
temp = 1
for i in range(1, 4000001):
    temp = temp * i % p
    fac.append(temp)

m = int(input())
for i in range(m):
    n, k = map(int, input().split())
    answer = (fac[n] % p) * power(fac[n - k], p - 2, p) * power(fac[k], p - 2, p) % p
    print(answer)
