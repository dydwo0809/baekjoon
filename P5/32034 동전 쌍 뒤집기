#include <bits/stdc++.h>

using namespace std;

typedef long long ll;


int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        int n;
        cin >> n;
        string s;
        cin >> s;

        ll answer = 0;
        deque<char> q;

        for (auto c : s) {
            if (q.empty()) {
                if (c == 'T') q.push_back(c);
                continue;
            }
            if (c != q.back()) q.push_back(c);
            else {
                answer += (ll)q.size();
                q.pop_back();
            }
            if (!q.empty() and q.front() == 'H') q.pop_front();
        }
        if (!q.empty()) answer = -1;
        cout << answer << '\n';
    }
}
