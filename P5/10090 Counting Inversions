#include <bits/stdc++.h>
using namespace std;

typedef long long ll;


void update(vector<ll> &tree, int node, int start, int end, int index, ll val) {
    if (index < start || index > end) {
        return;
    }
    if (start == end) {
        tree[node] += val;
        return;
    }
    update(tree, node * 2, start, (start+end) / 2, index, val);
    update(tree, node * 2 + 1, (start+end) / 2 + 1, end, index, val);

    tree[node] = tree[node * 2] + tree[node * 2 + 1];
}


ll query(vector<ll> &tree, int node, int start, int end, int left, int right) {
    if (left > end || right < start) {
        return 0;
    }
    if (left <= start && end <= right) {
        return tree[node];
    }
    ll l = query(tree, node * 2, start, (start+end) / 2, left, right);
    ll r = query(tree, node * 2 + 1, (start+end) / 2 + 1, end, left, right);
    return l + r;
}


int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(0);
    cout.tie(0);

    int n;
    cin >> n;

    vector<ll> s(n);
    for (int i = 0; i < n; i++){
        cin >> s[i];
    }

    int N = 1000001;
    int tree_size = N * 3;
    vector<ll> tree(tree_size);

    ll answer = 0;
    for (int i = 0; i < n; i++){
        update(tree, 1, 1, N, s[i], 1);
        answer += query(tree, 1, 1, N, s[i] + 1, N);
    }

    cout << answer;

   return 0;
}
