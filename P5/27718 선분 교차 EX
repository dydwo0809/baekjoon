#include <bits/stdc++.h>
using namespace std;

typedef long long ll;


int ccw(pair<ll, ll> v1, pair<ll, ll> v2){
   ll temp = v1.first * v2.second - v2.first * v1.second;
   if (temp > 0){
      return 1;
   }
   else if (temp == 0){
      return 0;
   }
   else{
      return -1;
   }
}


int ccwP(pair<ll, ll> p1, pair<ll, ll> p2, pair<ll, ll> p3){
   return ccw({p2.first - p1.first, p2.second - p1.second}, {p3.first - p1.first, p3.second - p1.second});
}


int sl(ll x1, ll x2, ll x3, ll x4){
   if (x3 > x2 || x4 < x1){
      return 0;
   }
   else if(x2 == x3 || x1 == x4){
      return 1;
   }
   else{
      return 3;
   }
}


int cross(vector<ll> v1, vector<ll> v2){
   pair<ll, ll> p1 = {v1[0], v1[1]};
   pair<ll, ll> p2 = {v1[2], v1[3]};
   pair<ll, ll> p3 = {v2[0], v2[1]};
   pair<ll, ll> p4 = {v2[2], v2[3]};

   int c1 = ccwP(p1 ,p2, p3);
   int c2 = ccwP(p1, p2, p4);

   int c3 = ccwP(p3, p4, p1);
   int c4 = ccwP(p3, p4, p2);

   int C1 = c1 * c2;
   int C2 = c3 * c4;

   if (C1 > 0 || C2 > 0){
      return 0;
   }
   else if (C1 < 0 && C2 < 0){
      return 2;
   }
   else if ((C1 < 0 && C2 == 0) || (C1 == 0 && C2 < 0)){
      return 1;
   }
   else if (C1 == 0 and C2 == 0){
      if(c1 + c2 != 0 || c3 + c4 != 0){
         return 1;
      }
      else{
         int x1, x2, x3, x4;
         if (p1.first == p2.first){
            if (p1.second < p2.second){
               x1 = p1.second;
               x2 = p2.second;
            }
            else{
               x1 = p2.second;
               x2 = p1.second;
            }
            if (p3.second < p4.second){
               x3 = p3.second;
               x4 = p4.second;
            }
            else{
               x3 = p4.second;
               x4 = p3.second;
            }
         }
         else{
            if (p1.first < p2.first){
               x1 = p1.first;
               x2 = p2.first;
            }
            else{
               x1 = p2.first;
               x2 = p1.first;
            }
            if (p3.first < p4.first){
               x3 = p3.first;
               x4 = p4.first;
            }
            else{
               x3 = p4.first;
               x4 = p3.first;
            }
         }
         return sl(x1, x2, x3, x4);
      }
   }
   else{
      return -1;
   }
}


int main() {
   ios_base::sync_with_stdio(false);
   cin.tie(0);
   cout.tie(0);

   int n;
   cin >> n;

   vector<vector<ll>> points(n, vector<ll>(4, 0));
   for (int i = 0; i < n; i++){
      cin >> points[i][0] >> points[i][1] >> points[i][2] >> points[i][3];
   }

   vector<vector<int>> answer(n, vector<int>(n, 3));
   for (int i = 0; i < n; i++){
      for (int j = i + 1; j < n; j++){
         int temp = cross(points[i], points[j]);
         answer[i][j] = temp;
         answer[j][i] = temp;
      }
   }

   for (int i = 0; i < n; i++){
      for (int j = 0; j < n; j++){
         cout << answer[i][j];
      }
      cout << "\n";
   }

   return 0;
}
