import sys
input = sys.stdin.readline

n, p = map(int, input().split())
a = list(map(int, input().split()))[::-1]

fermat = [0] * (p - 1)

for i in range(n + 1):
    fermat[i % (p - 1)] += a[i] % p

print(a[0] % p)
for i in range(1, p):
    answer = 0
    temp = 1
    for j in range(len(fermat)):
        answer += fermat[j] * temp
        answer %= p
        temp *= i
        temp %= p
    print(answer % p)
